# --- Providerzy LLM ---
AI_CORE_OPENAI_API_KEY=
AI_CORE_ANTHROPIC_API_KEY=
AI_CORE_LOCAL_API_BASE=http://localhost:11434

# --- Wybór backendu obserwowalności: langfuse | opik | none ---
AI_CORE_OBSERVABILITY_BACKEND=langfuse

# --- Langfuse ---
AI_CORE_LANGFUSE_PUBLIC_KEY=
AI_CORE_LANGFUSE_SECRET_KEY=
AI_CORE_LANGFUSE_HOST=https://cloud.langfuse.com

# --- Opik ---
AI_CORE_OPIK_API_KEY=
AI_CORE_OPIK_WORKSPACE=
# self-hosted, np. http://localhost:5173/api
AI_CORE_OPIK_URL_OVERRIDE=

# dev | staging | prod
AI_CORE_ENVIRONMENT=dev
